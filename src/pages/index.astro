---
import '../styles/global.css'
import Plum from '../components/Plum.vue'
import TypeWriter from '../components/TypeWriter.vue'

const currentYear = new Date().getFullYear()
---

<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WWDNX7ZYNX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-WWDNX7ZYNX');
    </script>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/prastavna.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Prastavna - Software Innovation Company</title>
		<meta name="description" content="Prastavna (प्रस्तावना) - Trying to fill the gaps in the internet" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		<style>
			body {
				font-family: 'Funnel Display', system-ui, sans-serif;
				background: #f8fafc;
			}
		</style>
	</head>
	<body class="min-h-screen text-slate-800 relative">
		<Plum client:load />
		
		<div class="min-h-screen flex flex-col relative z-10">
			<!-- Header -->
			<header class="p-6 lg:p-8">
				<div class="max-w-7xl mx-auto">
					<div class="flex items-center justify-between">
						<div class="flex items-center space-x-3">
							<img src="/prastavna.png" alt="Prastavna Logo" class="w-12 h-12 object-contain">
							<h1 class="text-2xl font-bold text-blue-500">
								Prastavna
							</h1>
						</div>
						<nav class="hidden md:flex space-x-8">
							<a href="#products" class="text-slate-600 hover:text-slate-900 transition-colors">Products</a>
							<a href="#contact" class="text-slate-600 hover:text-slate-900 transition-colors">Contact</a>
						</nav>
					</div>
				</div>
			</header>

			<!-- Hero Section -->
			<main class="flex-1 flex items-center justify-center px-6 lg:px-8">
				<div class="max-w-4xl mx-auto text-center">
					<div class="mb-8">
						<TypeWriter 
							client:load
							texts={[
								"Prastavna",
								"प्रस्तावना",
							]}
							typeSpeed={100}
							deleteSpeed={100}
							pauseDuration={2500}
							className="flex justify-center text-6xl lg:text-8xl font-bold mb-4 bg-gradient-to-r from-blue-500 via-blue-700 to-blue-500 bg-clip-text text-transparent"
							pulseClassName="inline-block w-0 animate-pulse"
						/>
					</div>
					
					<p class="text-xl lg:text-2xl text-slate-600 mb-8 max-w-3xl mx-auto leading-relaxed">
						Trying to fill the gaps in the internet. <br>
						Building software and hardware that might or might not be useful.
					</p>
					
					<div class="mb-12">
						<span class="inline-block px-6 py-3 bg-blue-50 border border-blue-300 rounded-full text-blue-700 text-lg font-medium">
							Coming Soon
						</span>
					</div>
				</div>
			</main>

			<!-- Products Preview Section -->
			<section id="products" class="px-6 lg:px-8 pb-16">
				<div class="max-w-6xl mx-auto">
					<h3 class="text-3xl font-bold text-center mb-12 text-blue-500">
						Our Products
					</h3>
					
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						<!-- Product 1: LeetCode Compensation -->
						<a href="https://leetcode-compensation.prastavna.com/" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<img src="/leetcode-compensation-logo.png" alt="LeetCode Compensation Logo" class="w-12 h-12 object-contain">
							</div>
							<h4 class="text-xl font-semibold mb-3 text-slate-800">LeetCode Compensation</h4>
							<p class="text-slate-600 leading-relaxed">
								Near real-time LeetCode compensation insights for India. Track software engineer salaries with automated data updates and intelligent parsing.
							</p>
						</a>

						<!-- Product 2: Xodeforces -->
						<a href="https://chromewebstore.google.com/detail/xodeforces/lnfgjljnmoickkgbjedecbkcmhhdncpk" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<img src="/xodeforces-logo.png" alt="Xodeforces Logo" class="w-12 h-12 object-contain">
							</div>
							<h4 class="text-xl font-semibold mb-3 text-slate-800">Xodeforces</h4>
							<p class="text-slate-600 leading-relaxed">
								Chrome extension that enhances Codeforces with an integrated Monaco code editor. Available on Chrome Web Store for competitive programming.
							</p>
						</a>

						<!-- Product 3: LeetCode Interview Questions -->
						<a href="https://leetcode-interview-questions.prastavna.com/" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<img src="/leetcode-interview-questions-logo.svg" alt="LeetCode Interview Questions Logo" class="w-12 h-12 object-contain">
							</div>
							<h4 class="text-xl font-semibold mb-3 text-slate-800">LeetCode Interview Questions</h4>
							<p class="text-slate-600 leading-relaxed">
								Automated pipeline that discovers and parses LeetCode interview discussions into a structured dataset with a Vue dashboard for insights.
							</p>
						</a>

						<!-- Product 4: Mock Screens -->
						<a href="https://chromewebstore.google.com/detail/mock-screens/lijniidfdfobehfefagkfkbepkkaipdm" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<img src="/mock-screens-logo.png" alt="Mock Screens Logo" class="w-12 h-12 object-contain">
							</div>
							<h4 class="text-xl font-semibold mb-3 text-slate-800">Mock Screens</h4>
							<p class="text-slate-600 leading-relaxed">
								Browser extension built with TypeScript and Vite to inject custom scripts and mock multi-screen behavior in modern browsers.
							</p>
						</a>

					<!-- Product 5: Use My Voucher -->
					<a href="http://usemyvoucher.prastavna.com/" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
						<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
							<img src="/usemyvoucher-logo.svg" alt="Use My Voucher Logo" class="w-12 h-12 object-contain">
						</div>
						<h4 class="text-xl font-semibold mb-3 text-slate-800">Use My Voucher</h4>
						<p class="text-slate-600 leading-relaxed">
							Community-powered voucher sharing app with contributor points, reports, and usage tracking built on Vue and Supabase.
						</p>
					</a>

					<!-- Product 6: emage -->
					<a href="https://prastavna.github.io/emage/" target="_blank" rel="noopener noreferrer" class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl block">
						<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
							<img src="/emage-logo.svg" alt="emage Logo" class="w-12 h-12 object-contain">
						</div>
						<h4 class="text-xl font-semibold mb-3 text-slate-800">emage</h4>
						<p class="text-slate-600 leading-relaxed">
							Privacy-first image manipulation tool that runs entirely in your browser. Crop, rotate, filter, resize—all without uploading.
						</p>
					</a>

					<!-- Product 7: Coming Soon -->
						<div class="bg-white/70 backdrop-blur-sm border border-slate-200 rounded-xl p-6 hover:border-blue-300 transition-all duration-300 hover:transform hover:scale-105 shadow-lg hover:shadow-xl">
							<div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-blue-600 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
								</svg>
							</div>
							<h4 class="text-xl font-semibold mb-3 text-slate-800">More Exciting Stuff</h4>
							<p class="text-slate-600 leading-relaxed">
								We're working on something amazing! Stay tuned for our next innovative project that will enhance your development experience.
							</p>
							<div class="mt-4">
								<span class="inline-block px-3 py-1 bg-blue-50 border border-blue-300 rounded-full text-blue-700 text-sm font-medium">
									Coming Soon
								</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Footer -->
			<footer class="border-t border-slate-300 px-6 lg:px-8 py-8" id="contact">
				<div class="max-w-7xl mx-auto">
					<div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
						<div class="flex items-center space-x-3">
							<img src="/prastavna.png" alt="Prastavna Logo" class="w-8 h-8 object-contain">
							<span class="text-slate-600">© {currentYear} Prastavna. All rights reserved.</span>
						</div>
						
						<!-- Social Media Links -->
						<div class="flex items-center space-x-4">
							<span class="text-slate-500 text-sm">Follow us:</span>
							<div class="flex space-x-3">
								<a href="https://twitter.com/prastavna" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-slate-100 hover:bg-slate-200 rounded-lg flex items-center justify-center transition-colors group" aria-label="Twitter">
									<svg class="w-5 h-5 text-slate-600 group-hover:text-slate-800" fill="currentColor" viewBox="0 0 24 24">
										<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
									</svg>
								</a>
								<a href="https://github.com/prastavna" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-slate-100 hover:bg-slate-200 rounded-lg flex items-center justify-center transition-colors group" aria-label="GitHub">
									<svg class="w-5 h-5 text-slate-600 group-hover:text-slate-800" fill="currentColor" viewBox="0 0 24 24">
										<path d="M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
									</svg>
								</a>
								<a href="https://linkedin.com/company/prastavna" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-slate-100 hover:bg-slate-200 rounded-lg flex items-center justify-center transition-colors group" aria-label="LinkedIn">
									<svg class="w-5 h-5 text-slate-600 group-hover:text-slate-800" fill="currentColor" viewBox="0 0 24 24">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>
								<a href="mailto:hello@prastavna.com" class="w-10 h-10 bg-slate-100 hover:bg-slate-200 rounded-lg flex items-center justify-center transition-colors group" aria-label="Email">
									<svg class="w-5 h-5 text-slate-600 group-hover:text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
